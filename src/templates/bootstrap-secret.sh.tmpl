#!/usr/bin/env bash
# bootstrap-secret — drop a secret into macOS Keychain with the install's namespace.
#
# Usage: ./bootstrap-secret <name> <value>
# Example: ./bootstrap-secret {{label}}_slack_bot_token xoxb-...

set -euo pipefail

LABEL="{{label}}"

if [ "$#" -ne 2 ]; then
  echo "usage: $0 <name> <value>" >&2
  echo "  example: $0 ${LABEL}_slack_bot_token xoxb-..." >&2
  exit 2
fi

NAME="$1"
VALUE="$2"

# Namespace check — refuse if the name doesn't start with the install label.
case "$NAME" in
  "${LABEL}_"*)
    ;;
  *)
    echo "✗ secret name must start with '${LABEL}_' for namespace isolation; got '$NAME'" >&2
    exit 3
    ;;
esac

# Delete + add (security add-generic-password is idempotent if you delete first).
security delete-generic-password -a "$USER" -s "$NAME" >/dev/null 2>&1 || true
security add-generic-password -a "$USER" -s "$NAME" -w "$VALUE"

echo "✓ stored Keychain entry '$NAME'"
